{
    // Do not edit, settings provided by base image
    // override at the user or workspace level instead
    "chat.useAgentSkills": true,
    "chat.useNestedAgentsMdFiles": true,
    "chat.useClaudeHooks": true,
    "inlineChat.notebookAgent": true,
    "github.copilot.chat.claudeAgent.enabled": false,
    "github.copilot.chat.notebook.enhancedNextEditSuggestions.enabled": true,
    "github.copilot.chat.notebook.followCellExecution.enabled": true,
    "github.copilot.nextEditSuggestions.enabled": true,
    "jupyter.notebookFileRoot": "/code",
    "git.useIntegratedAskPass": false,
    "github.gitAuthentication": false,
    "remote.autoForwardPortsSource": "hybrid",
    "basedpyright.analysis.inlayHints.variableTypes": false,
    "basedpyright.analysis.inlayHints.functionReturnTypes": false,
    "basedpyright.analysis.inlayHints.callArgumentNames": false,
    "basedpyright.analysis.inlayHints.genericTypes": false,
    "basedpyright.analysis.typeCheckingMode": "off",
    "basedpyright.analysis.exclude": [
        "results/**",
        "data/**",
        "scratch/**"
    ],
    "python.languageServer": "None"
}